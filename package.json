{
  "name": "power-apps-template-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "bash -c 'output=$(pac code run 2>&1); printf \"%s\\n\" \"$output\" | sed \"s|http://localhost|https://localhost|g\" && vite'",
    "build": "tsc -b && vite build && pac code push",
